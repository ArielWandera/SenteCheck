# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sentecheck

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=0000000000:your_token_here

# Shared secret between the Android app and the backend.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=replace_with_a_random_64_char_hex_string

# Public HTTPS URL of this deployment (used to register the Telegram webhook)
FASTAPI_BASE_URL=https://your-app.railway.app

# Fernet key for encrypting raw SMS at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# Set to "production" on Railway; leave as "development" locally
ENVIRONMENT=development
